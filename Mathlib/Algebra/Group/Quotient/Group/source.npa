  forall (G : Sort succ u), forall (one : G), forall (mul : forall (a : G), forall (b : G), G), forall (inv : forall (a : G), G), forall (N : forall (x : G), Prop), forall (group_args : @GroupLawArgs.{succ u} G one mul inv), forall (normal_args : @NormalSubgroupLawArgs.{succ u} G one mul inv N), forall (q1 : @NormalQuotient.{u} G one mul inv N group_args normal_args), forall (q2 : @NormalQuotient.{u} G one mul inv N group_args normal_args), forall (q3 : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q1 q2) q3) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q1 (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q2 q3)) :=
  fun G => fun one => fun mul => fun inv => fun N => fun group_args => fun normal_args => @Quotient.indProp.{u} G (@NormalSetoid.{u} G one mul inv N group_args normal_args) (fun (q1 : @NormalQuotient.{u} G one mul inv N group_args normal_args) => forall (q2 : @NormalQuotient.{u} G one mul inv N group_args normal_args), forall (q3 : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q1 q2) q3) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q1 (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q2 q3))) (fun (a : G) => @Quotient.indProp.{u} G (@NormalSetoid.{u} G one mul inv N group_args normal_args) (fun (q2 : @NormalQuotient.{u} G one mul inv N group_args normal_args) => forall (q3 : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMk.{u} G one mul inv N group_args normal_args a) q2) q3) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMk.{u} G one mul inv N group_args normal_args a) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q2 q3))) (fun (b : G) => @Quotient.indProp.{u} G (@NormalSetoid.{u} G one mul inv N group_args normal_args) (fun (q3 : @NormalQuotient.{u} G one mul inv N group_args normal_args) => @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMk.{u} G one mul inv N group_args normal_args a) (@NormalQuotientMk.{u} G one mul inv N group_args normal_args b)) q3) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMk.{u} G one mul inv N group_args normal_args a) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientMk.{u} G one mul inv N group_args normal_args b) q3))) (fun (c : G) => @normal_quot_sound.{u} G one mul inv N group_args normal_args (mul (mul a b) c) (mul a (mul b c)) (@normal_rel_of_eq.{succ u} G one mul inv group_args N normal_args (mul (mul a b) c) (mul a (mul b c)) (@group_mul_assoc.{succ u} G one mul inv group_args a b c)))))

theorem normal_quot_one_mul.{u} :
  forall (G : Sort succ u), forall (one : G), forall (mul : forall (a : G), forall (b : G), G), forall (inv : forall (a : G), G), forall (N : forall (x : G), Prop), forall (group_args : @GroupLawArgs.{succ u} G one mul inv), forall (normal_args : @NormalSubgroupLawArgs.{succ u} G one mul inv N), forall (q : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientOne.{u} G one mul inv N group_args normal_args) q) q :=
  fun G => fun one => fun mul => fun inv => fun N => fun group_args => fun normal_args => @Quotient.indProp.{u} G (@NormalSetoid.{u} G one mul inv N group_args normal_args) (fun (q : @NormalQuotient.{u} G one mul inv N group_args normal_args) => @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientOne.{u} G one mul inv N group_args normal_args) q) q) (fun (a : G) => @normal_quot_sound.{u} G one mul inv N group_args normal_args (mul one a) a (@normal_rel_of_eq.{succ u} G one mul inv group_args N normal_args (mul one a) a (@group_one_mul.{succ u} G one mul inv group_args a)))

theorem normal_quot_mul_one.{u} :
  forall (G : Sort succ u), forall (one : G), forall (mul : forall (a : G), forall (b : G), G), forall (inv : forall (a : G), G), forall (N : forall (x : G), Prop), forall (group_args : @GroupLawArgs.{succ u} G one mul inv), forall (normal_args : @NormalSubgroupLawArgs.{succ u} G one mul inv N), forall (q : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q (@NormalQuotientOne.{u} G one mul inv N group_args normal_args)) q :=
  fun G => fun one => fun mul => fun inv => fun N => fun group_args => fun normal_args => @Quotient.indProp.{u} G (@NormalSetoid.{u} G one mul inv N group_args normal_args) (fun (q : @NormalQuotient.{u} G one mul inv N group_args normal_args) => @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q (@NormalQuotientOne.{u} G one mul inv N group_args normal_args)) q) (fun (a : G) => @normal_quot_sound.{u} G one mul inv N group_args normal_args (mul a one) a (@normal_rel_of_eq.{succ u} G one mul inv group_args N normal_args (mul a one) a (@group_mul_one.{succ u} G one mul inv group_args a)))

theorem normal_quot_inv_mul.{u} :
  forall (G : Sort succ u), forall (one : G), forall (mul : forall (a : G), forall (b : G), G), forall (inv : forall (a : G), G), forall (N : forall (x : G), Prop), forall (group_args : @GroupLawArgs.{succ u} G one mul inv), forall (normal_args : @NormalSubgroupLawArgs.{succ u} G one mul inv N), forall (q : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args (@NormalQuotientInv.{u} G one mul inv N group_args normal_args q) q) (@NormalQuotientOne.{u} G one mul inv N group_args normal_args) :=
