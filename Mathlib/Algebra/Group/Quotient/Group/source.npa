theorem normal_quot_mul_inv.{u} :
  forall (G : Sort succ u), forall (one : G), forall (mul : forall (a : G), forall (b : G), G), forall (inv : forall (a : G), G), forall (N : forall (x : G), Prop), forall (group_args : @GroupLawArgs.{succ u} G one mul inv), forall (normal_args : @NormalSubgroupLawArgs.{succ u} G one mul inv N), forall (q : @NormalQuotient.{u} G one mul inv N group_args normal_args), @Eq.{succ u} (@NormalQuotient.{u} G one mul inv N group_args normal_args) (@NormalQuotientMul.{u} G one mul inv N group_args normal_args q (@NormalQuotientInv.{u} G one mul inv N group_args normal_args q)) (@NormalQuotientOne.{u} G one mul inv N group_args normal_args) :=
